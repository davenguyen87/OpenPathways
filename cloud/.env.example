# Prism Cloud — example env for `docker compose up`.
#
# Copy to cloud/.env and fill in the secrets. The defaults below let you
# bring everything up locally; production deploys put these in Coolify's
# secrets UI (see cloud/DEPLOY.md) and never check them into git.

# ---- Postgres (used by docker-compose) ----
POSTGRES_DB=openpathways
POSTGRES_USER=openpathways
POSTGRES_PASSWORD=openpathways

# ---- S3 / MinIO ----
S3_BUCKET=op-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ---- Auth ----
# 32+ random bytes hex. Generate with: openssl rand -hex 32
SESSION_SECRET=replace_me_with_32_or_more_random_hex_chars_replaceme

# Authentication adapter. Default: magic-link (required for production).
# Set to 'none' to disable auth entirely (TESTING ONLY).
# AUTH_ADAPTER=none

# At least one of these is required in hosted mode (when not using AUTH_ADAPTER=none).
ALLOWLIST_EMAIL_DOMAINS=example.com
# ALLOWLIST_EMAILS=alice@gmail.com,bob@gmail.com

# ---- SMTP (production) ----
# Leave blank to use MAIL_CAPTURE_DIR for local dev. Coolify deploys fill
# these in with real credentials (Postmark/SES/Mailgun/etc).
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Prism <noreply@yourdomain.com>
# SMTP_SECURE=false

# ---- Public URL ----
# Used inside magic-link emails. For local docker-compose: http://localhost:4280
# For production: https://op.yourdomain.com
PUBLIC_BASE_URL=http://localhost:4280

# ---- Operational ----
# Time-based retention. 0 = forever; production typically 30.
PRISM_RETENTION_DAYS=30

# Per-user quotas.
QUOTA_CONCURRENT_JOBS=2
QUOTA_UPLOADS_PER_DAY=50
QUOTA_STORED_BYTES=5368709120

# 80%-cap disk eviction. 0 = disabled. Set to your bucket capacity to
# enable proactive cleanup.
QUOTA_STORED_BYTES_TOTAL=0

# Worker concurrency on an 8 GB VPS. The roadmap recommends 3.
WORKER_CONCURRENCY=3

# Set to "true" when behind a TLS-terminating reverse proxy (Coolify is).
PRISM_BEHIND_TLS=false
