  "bin": {
    "open-pathways": "src/cli.js"
  },
  "type": "commonjs",
  "scripts": {
    "start": "node src/cli.js",
    "test": "vitest"
  },
  "keywords": [
    "scorm",
    "aicc",
    "wcag",
    "accessibility",
    "audit",
    "compliance"
  ],
  "author": "Dave Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davenguyen87/OpenPathways.git"
  },
  "bugs": {
    "url": "https://github.com/davenguyen87/OpenPathways/issues"
  },
  "homepage": "https://github.com/davenguyen87/OpenPathways#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axe-core": "^4.8.0",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^12.0.0",
    "jsdom": "^23.2.0",
    "kleur": "^4.1.5",
    "ora": "^8.0.0",
    "xml2js": "^0.6.2",
    "yauzl": "^3.1.2",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
